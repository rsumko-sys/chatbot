[flake8]
exclude =
    .venv,
    .git,
    __pycache__,
    artifacts
max-line-length = 130
ignore = E302,E305
per-file-ignores =
    # bot.py and generator.py contain stub/placeholder code (# ...existing code...)
    # their imports will be used when the full implementation is filled in
    bot.py: F401
    generator.py: F401
