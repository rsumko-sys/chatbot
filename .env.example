# ── Telegram Bot ────────────────────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here
TARGET_CHAT_ID=your_target_chat_id_here

# ── Timezone & Schedule ──────────────────────────────────────────────────────
TZ_NAME="Europe/Kyiv"
MORNING_AT="07:30"
DAY_AT="13:00"
EVENING_AT="21:00"
SNOOZE_MINUTES_DEFAULT="30"
CRITICAL_CHASE_MINUTES="60"

# ── Database ─────────────────────────────────────────────────────────────────
DB_PATH="bot.db"

# ── Weather API ───────────────────────────────────────────────────────────────
# Get a free API key at https://openweathermap.org/api
OPENWEATHER_API_KEY=your_openweather_api_key_here

# ── Next.js / Vercel (web interface) ─────────────────────────────────────────
# Generate a random secret: https://generate-secret.vercel.app/32 or `openssl rand -base64 32`
AUTH_SECRET=****

# Instructions to create an AI Gateway API key here: https://vercel.com/ai-gateway
# API key required for non-Vercel deployments
AI_GATEWAY_API_KEY=****

# Instructions to create a Vercel Blob Store here: https://vercel.com/docs/vercel-blob
BLOB_READ_WRITE_TOKEN=****

# Instructions to create a PostgreSQL database here: https://vercel.com/docs/postgres
POSTGRES_URL=****

# Instructions to create a Redis store here: https://vercel.com/docs/redis
REDIS_URL=****
