# === Telegram Bot (Python) ===
# Get your bot token from @BotFather on Telegram
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here
# The chat or user ID where the bot will send scheduled messages
# You can get it by messaging @userinfobot on Telegram
TARGET_CHAT_ID=your_target_chat_id_here
# IANA timezone name — used for scheduling and display
TZ_NAME="Europe/Kyiv"
# Time for daily morning / day / evening messages (HH:MM, 24-hour)
MORNING_AT="07:30"
DAY_AT="13:00"
EVENING_AT="21:00"
# How many minutes to wait before a snooze reminder fires
SNOOZE_MINUTES_DEFAULT="30"
# How many minutes after a message before chasing uncompleted critical tasks
CRITICAL_CHASE_MINUTES="60"
# Path to the SQLite database file (inside the container this should be /data/bot.db)
DB_PATH="bot.db"
# Optional: OpenWeatherMap API key for weather in messages
# Leave empty to disable weather — https://openweathermap.org/api
OPENWEATHER_API_KEY=your_openweather_api_key_here

# === Next.js Chatbot ===
# Generate a random secret: https://generate-secret.vercel.app/32 or `openssl rand -base64 32`
AUTH_SECRET=****

# The following keys below are automatically created and
# added to your environment when you deploy on Vercel

# Instructions to create an AI Gateway API key here: https://vercel.com/ai-gateway 
# API key required for non-Vercel deployments
# For Vercel deployments, OIDC tokens are used automatically
# https://vercel.com/ai-gateway
AI_GATEWAY_API_KEY=****


# Instructions to create a Vercel Blob Store here: https://vercel.com/docs/vercel-blob
BLOB_READ_WRITE_TOKEN=****

# Instructions to create a PostgreSQL database here: https://vercel.com/docs/postgres
POSTGRES_URL=****


# Instructions to create a Redis store here:
# https://vercel.com/docs/redis
REDIS_URL=****
